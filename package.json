{
  "name": "glm-chat-provider",
  "displayName": "GLM Chat Provider",
  "description": "Z.AI GLM models as VS Code Language Model Chat Provider",
  "version": "0.6.1",
  "publisher": "DenizhanDaklr",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/zelosleone/glm-chat-provider"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "glm",
    "Z.AI",
    "ai",
    "chat",
    "copilot"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelChatProvider:zai"
  ],
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "zai",
        "displayName": "Z.AI GLM",
        "configuration": {
          "type": "object",
          "properties": {
            "apiKey": {
              "type": "string",
              "secret": true,
              "title": "API Key",
              "description": "API key for Z.AI GLM (from z.ai console)"
            }
          },
          "required": [
            "apiKey"
          ]
        }
      }
    ],
    "configuration": {
      "title": "GLM Chat Provider",
      "properties": {
        "glm-chat-provider.defaultThinkingMode": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "enabled",
            "disabled"
          ],
          "enumDescriptions": [
            "Let the model decide when to think (default behavior)",
            "Always enable thinking mode",
            "Always disable thinking mode"
          ],
          "description": "Default thinking mode for GLM models that support it (GLM-4.5+)"
        },
        "glm-chat-provider.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 1,
          "description": "Default temperature when 'Custom' is selected in model picker. Use 'GLM: Set Temperature' command for presets + custom.",
          "scope": "application"
        }
      }
    },
    "commands": [
      {
        "command": "glm-chat-provider.setApiKey",
        "title": "GLM: Set API Key"
      },
      {
        "command": "glm-chat-provider.clearApiKey",
        "title": "GLM: Clear API Key"
      },
      {
        "command": "glm-chat-provider.manage",
        "title": "GLM: Manage Provider"
      },
      {
        "command": "glm-chat-provider.setThinkingEffort",
        "title": "GLM: Set Thinking Effort"
      },
      {
        "command": "glm-chat-provider.setTemperature",
        "title": "GLM: Set Temperature"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "build": "npm run bundle",
    "bundle": "node bundle.mjs",
    "compile": "tsc",
    "watch": "tsc -watch -p ./",
    "lint": "gts lint",
    "clean": "gts clean",
    "fix": "gts fix",
    "prepare": "npm.cmd run compile",
    "pretest": "npm.cmd run compile",
    "posttest": "npm.cmd run lint"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/vscode": "1.116.0",
    "esbuild": "^0.28.0",
    "eslint": "9.39.2",
    "gts": "^7.0.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "openai": "^6.34.0",
    "secure-json-parse": "^4.1.0",
    "ts-pattern": "^5.9.0"
  },
  "overrides": {
    "tmp": "0.2.5"
  }
}
